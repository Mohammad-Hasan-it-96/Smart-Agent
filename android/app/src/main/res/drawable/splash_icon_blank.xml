<?xml version="1.0" encoding="utf-8"?>
<!-- Transparent 1x1 drawable used as the system splash icon.
     This makes the Android system splash show ONLY the navy background
     with no visible icon, so the Flutter animated splash is the one
     and only splash the user sees. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#00000000"/>
    <size android:width="1dp" android:height="1dp"/>
</shape>

